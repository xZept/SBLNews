@page "/"
@using MudBlazor

<PageTitle>SBLNews</PageTitle>

<MudPaper Elevation="0" Style="background-color: transparent;">
    <MudList T="NewsItem" Class="py-0">
        @foreach (var item in _dummyData)
        {
            <MudListItem T="NewsItem" Class="pa-2">
                <div class="d-flex align-start">
                    
                    <div class="d-flex flex-column align-center mr-3" style="width: 45px;">
                        <MudText Typo="Typo.body2" Style="color: #64748b;">@item.Id.</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDropUp" Size="Size.Small" Class="pa-0" Style="color: #64748b;" />
                        <MudText Typo="Typo.caption" Style="font-weight: bold; color: #0F172A;">@item.Score</MudText>
                    </div>

                    <div class="d-flex flex-column">
                        <div>
                            <MudText Typo="Typo.body1" Style="font-weight: 500; display: inline;">@item.Title</MudText>
                            <MudText Typo="Typo.caption" Class="ml-1" Style="color: #64748b;">(@item.Domain)</MudText>
                        </div>
                        <div class="mt-1">
                            <MudText Typo="Typo.caption" Style="color: #64748b;">
                                by <span style="font-weight: 500;">@item.Author</span> @item.TimeAgo | @item.CommentCount comments
                            </MudText>
                        </div>
                    </div>

                </div>
            </MudListItem>
        }
    </MudList>
</MudPaper>

@code {
    // The Blueprint (Model) for a Study
    public class NewsItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Domain { get; set; } = "";
        public int Score { get; set; }
        public string Author { get; set; } = "";
        public string TimeAgo { get; set; } = "";
        public int CommentCount { get; set; }
    }

    // The Dummy Data
    private List<NewsItem> _dummyData = new()
    {
        new NewsItem { Id = 1, Title = "CRISPR-Cas9 gene editing for sickle cell disease", Domain = "nejm.org", Score = 466, Author = "biohacker", TimeAgo = "5 hours ago", CommentCount = 432 },
        new NewsItem { Id = 2, Title = "A new antibiotic from an uncultured bacterium", Domain = "nature.com", Score = 325, Author = "microdoc", TimeAgo = "8 hours ago", CommentCount = 125 },
        new NewsItem { Id = 3, Title = "Quantum supremacy using a programmable superconducting processor", Domain = "nature.com", Score = 231, Author = "qbit", TimeAgo = "10 hours ago", CommentCount = 78 },
        new NewsItem { Id = 4, Title = "AlphaFold: a solution to a 50-year-old grand challenge in biology", Domain = "deepmind.com", Score = 122, Author = "ai_enthusiast", TimeAgo = "12 hours ago", CommentCount = 32 }
    };
}