@page "/"
@using MudBlazor
@using SBLNews.Models
@using SBLNews.Services
@inject IScienceNewsService ScienceNewsService 

<PageTitle>SBLNews</PageTitle>

<MudPaper Elevation="0" Style="background-color: transparent;">
    @if (_studies == null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-4 mx-auto d-block" />
    }
    else
    {
        <MudList T="PaperData" Class="py-0">
            @foreach (var (item, index) in _studies.Select((value, i) => (value, i)))
            {
                <MudListItem T="PaperData" Class="pa-2">
                    <div class="d-flex align-start">
                        
                        <div class="d-flex flex-column align-center mr-3" style="width: 45px;">
                            <MudText Typo="Typo.body2" Style="color: #64748b;">@(index + 1).</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowDropUp" Size="Size.Small" Class="pa-0" Style="color: #64748b;" />
                            <MudText Typo="Typo.caption" Style="font-weight: bold; color: #0F172A;">1</MudText> 
                        </div>

                        <div class="d-flex flex-column">
                            <div>
                                <MudText Typo="Typo.body1" Style="font-weight: 500; display: inline;">@item.Title</MudText>
                                <MudText Typo="Typo.caption" Class="ml-1" Style="color: #64748b;">(pubmed.gov)</MudText>
                            </div>
                            <div class="mt-1">
                                <MudText Typo="Typo.caption" Style="color: #64748b;">
                                    by <span style="font-weight: 500;">@(item.Authors.FirstOrDefault()?.Name ?? "Unknown")</span> | Year: @item.Year
                                </MudText>
                            </div>
                        </div>

                    </div>
                </MudListItem>
            }
        </MudList>
    }
</MudPaper>

@code {
    private List<PaperData>? _studies;

    protected override async Task OnInitializedAsync()
    {
        // When the page loads, fetch real studies about "artificial intelligence"
        _studies = await ScienceNewsService.GetRecentStudiesAsync("artificial intelligence");
    }
}